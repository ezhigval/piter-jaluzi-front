---
const { product } = Astro.props;
---
<div class="product-card product-item" data-category={product.category} data-product-id={product.id}>
  <img src={product.image} alt={product.name} class="product-card-img" loading="lazy" />
  <div class="product-card-body">
    <span class="product-card-category">{product.category}</span>
    <h3 class="product-card-title">{product.name}</h3>
    <p class="product-card-price">от <strong>{product.price} ₽</strong>/м²</p>
    <span style="color:var(--color-primary);font-weight:500;">Подробнее →</span>
  </div>
</div>

<div id="modal-{product.id}" class="modal-overlay" data-modal-product-id={product.id}>
  <div class="modal-content">
    <button class="modal-close-btn" data-close-modal>×</button>
    <img src={product.image} alt={product.name} style="width:100%;height:250px;object-fit:cover;" />
    <div style="padding:1.5rem;">
      <span style="color:var(--color-primary);font-size:0.8rem;">{product.category}</span>
      <h2 style="font-size:1.5rem;margin:0.5rem 0;">{product.name}</h2>
      <p style="color:var(--color-text-muted);margin:1rem 0;line-height:1.7;">{product.description}</p>
      <div style="font-size:1.5rem;font-weight:bold;color:var(--color-primary);margin:1.5rem 0;">от {product.price} ₽/м²</div>
      <button data-open-order-modal data-close-modal class="btn btn-primary" style="width:100%;">Заказать</button>
    </div>
  </div>
</div>
