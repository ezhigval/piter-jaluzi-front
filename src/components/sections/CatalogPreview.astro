---
import ProductCard from '../ui/ProductCard.astro';
import config from '../../data/config.json';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';

let products = [];
let loadError = false;

try {
  const res = await fetch(API_URL + '/api/products');
  const data = await res.json();
  if (data.success) {
    products = data.data.slice(0, 3);
  } else {
    loadError = true;
  }
} catch (error) {
  console.error('Failed to load products:', error);
  loadError = true;
}
---
<section id="catalog" class="section">
  <div class="container">
    <h2 class="section-title">Каталог</h2>
    
    {loadError ? (
      <div style="text-align:center;padding:2rem;background:#FEF2F2;border-radius:1rem;margin-bottom:2rem;">
        <p style="color:#DC2626;">Не удалось загрузить товары</p>
      </div>
    ) : (
      <>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;margin-bottom:3rem;">
          {products.map(product => (<ProductCard product={product} />))}
        </div>
        <div style="text-align:center;display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="/catalog" class="btn btn-primary">Смотреть весь каталог</a>
          <button data-open-order-modal class="btn btn-outline">Заказать жалюзи</button>
        </div>
      </>
    )}
  </div>
</section>

{products.map(product => (
  <div id="modal-{product.id}" class="modal-overlay" data-modal-product-id={product.id}>
    <div class="modal-content">
      <button class="modal-close-btn" data-close-modal>×</button>
      <img src={product.image} alt={product.name} style="width:100%;height:250px;object-fit:cover;" />
      <div style="padding:1.5rem;">
        <span style="color:var(--color-primary);font-size:0.8rem;">{product.category}</span>
        <h2 style="font-size:1.5rem;margin:0.5rem 0;">{product.name}</h2>
        <p style="color:var(--color-text-muted);margin:1rem 0;line-height:1.7;">{product.description}</p>
        <div style="font-size:1.5rem;font-weight:bold;color:var(--color-primary);margin:1.5rem 0;">от {product.price} ₽/м²</div>
        <button data-open-order-modal data-close-modal class="btn btn-primary" style="width:100%;">Заказать</button>
      </div>
    </div>
  </div>
))}
