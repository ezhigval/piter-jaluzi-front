---
const features = [
  { icon: '📏', title: 'Бесплатный замер', desc: 'Приедем в удобное время' },
  { icon: '🛡️', title: 'Гарантия 1 год', desc: 'На все виды изделий' },
  { icon: '⚡', title: 'Производство 3 дня', desc: 'Собственный цех' },
  { icon: '🏆', title: 'На рынке 18 лет', desc: 'С 2006 года' },
];
---
<section style="padding:4rem 1.5rem;background:#F8FAFC;">
  <div style="max-width:1200px;margin:0 auto;">
    <h2 style="text-align:center;font-size:clamp(1.5rem, 4vw, 2rem);margin-bottom:3rem;color:#0F172A;">Наши преимущества</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.5rem;">
      {features.map(feature => (
        <div style="background:white;padding:2rem;border-radius:0.5rem;text-align:center;box-shadow:0 4px 6px rgba(0,0,0,0.1);">
          <div style="font-size:2.5rem;margin-bottom:1rem;">{feature.icon}</div>
          <h3 style="font-size:1.125rem;margin-bottom:0.5rem;color:#0F172A;">{feature.title}</h3>
          <p style="color:#64748B;font-size:0.95rem;">{feature.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @media (max-width: 640px) {
    section { padding: 3rem 1rem; }
    div[style*="grid"] { grid-template-columns: 1fr; }
  }
</style>
