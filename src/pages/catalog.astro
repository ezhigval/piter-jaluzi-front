---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrderModal from '../components/ui/OrderModal.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import config from '../data/config.json';
---
<BaseLayout 
  title={`Каталог жалюзи | ${config.company.name}`} 
  description="Широкий выбор жалюзи."
>
  <OrderModal />
  <Header />
  <section class="section">
    <div class="container">
      <h1 class="section-title">Каталог жалюзи</h1>
      
      <div id="category-filters" style="display:flex;gap:0.75rem;margin-bottom:2rem;flex-wrap:wrap;justify-content:center;">
        <button data-category="Все" class="btn" style="border:2px solid #CBD5E1;border-radius:2rem;background:#2563EB;color:white;font-weight:500;font-size:0.9rem;">Все</button>
        <button data-category="Рулонные" class="btn" style="border:2px solid #CBD5E1;border-radius:2rem;background:white;color:#0F172A;font-weight:500;font-size:0.9rem;">Рулонные</button>
        <button data-category="Вертикальные" class="btn" style="border:2px solid #CBD5E1;border-radius:2rem;background:white;color:#0F172A;font-weight:500;font-size:0.9rem;">Вертикальные</button>
        <button data-category="Горизонтальные" class="btn" style="border:2px solid #CBD5E1;border-radius:2rem;background:white;color:#0F172A;font-weight:500;font-size:0.9rem;">Горизонтальные</button>
      </div>
      
      <div id="products-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;">
        <!-- Товары загружаются через JS -->
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>

<script type="module">
  const API_URL = document.body.dataset.apiUrl || 'http://localhost:3001';
  
  async function loadProducts() {
    try {
      const res = await fetch(API_URL + '/api/products');
      const data = await res.json();
      if (data.success) {
        renderProducts(data.data);
        initFilters(data.data);
        initProductModals();
      }
    } catch (error) {
      console.error('Failed to load products:', error);
      document.getElementById('products-grid').innerHTML = 
        '<p style="text-align:center;color:#DC2626;grid-column:1/-1;">Не удалось загрузить товары</p>';
    }
  }
  
  function renderProducts(products) {
    const grid = document.getElementById('products-grid');
    grid.innerHTML = products.map(p => `
      <div class="product-card product-item" data-category="${p.category}" data-product-id="${p.id}">
        <img src="${p.image}" alt="${p.name}" class="product-card-img" loading="lazy" />
        <div class="product-card-body">
          <span class="product-card-category">${p.category}</span>
          <h3 class="product-card-title">${p.name}</h3>
          <p class="product-card-price">от <strong>${p.price} ₽</strong>/м²</p>
          <span style="color:var(--color-primary);font-weight:500;">Подробнее →</span>
        </div>
      </div>
      <div id="modal-${p.id}" class="modal-overlay" data-modal-product-id="${p.id}">
        <div class="modal-content">
          <button class="modal-close-btn" data-close-modal>×</button>
          <img src="${p.image}" alt="${p.name}" style="width:100%;height:250px;object-fit:cover;" />
          <div style="padding:1.5rem;">
            <span style="color:var(--color-primary);font-size:0.8rem;">${p.category}</span>
            <h2 style="font-size:1.5rem;margin:0.5rem 0;">${p.name}</h2>
            <p style="color:var(--color-text-muted);margin:1rem 0;line-height:1.7;">${p.description}</p>
            <div style="font-size:1.5rem;font-weight:bold;color:var(--color-primary);margin:1.5rem 0;">от ${p.price} ₽/м²</div>
            <button data-open-order-modal data-close-modal class="btn btn-primary" style="width:100%;">Заказать</button>
          </div>
        </div>
      </div>
    `).join('');
  }
  
  function initFilters(products) {
    document.querySelectorAll('#category-filters button').forEach(btn => {
      btn.addEventListener('click', function() {
        const cat = this.getAttribute('data-category');
        document.querySelectorAll('#category-filters button').forEach(b => { 
          b.style.background = 'white'; b.style.color = '#0F172A'; 
        });
        this.style.background = '#2563EB'; this.style.color = 'white';
        document.querySelectorAll('.product-item').forEach(item => {
          const ic = item.getAttribute('data-category');
          item.style.display = (cat === 'Все' || ic === cat) ? 'block' : 'none';
        });
      });
    });
  }
  
  function initProductModals() {
    document.addEventListener('click', function(e) {
      const card = e.target.closest('.product-card');
      if (card && !e.target.closest('.modal-content')) {
        const productId = card.getAttribute('data-product-id');
        const modal = document.querySelector(`.modal-overlay[data-modal-product-id="${productId}"]`);
        if (modal) { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
      }
      const closeBtn = e.target.closest('[data-close-modal]');
      if (closeBtn) {
        const modal = closeBtn.closest('.modal-overlay');
        if (modal) { modal.style.display = 'none'; document.body.style.overflow = ''; }
      }
      const modalOverlay = e.target.closest('.modal-overlay');
      if (modalOverlay && e.target === modalOverlay) {
        modalOverlay.style.display = 'none'; document.body.style.overflow = '';
      }
    });
  }
  
  loadProducts();
</script>
