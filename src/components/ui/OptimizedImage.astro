---
// Встроенный компонент Image из Astro 4
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  class?: string;
  fetchPriority?: 'high' | 'low' | 'auto';
  format?: 'auto' | 'avif' | 'webp';
}

const { 
  src, 
  alt, 
  width = 800, 
  height = 600, 
  loading = 'lazy',
  class: className = '',
  fetchPriority = 'auto',
  format = 'auto'
} = Astro.props;

// Для внешних изображений используем обычный img
const isExternal = src.startsWith('http');
---

{isExternal ? (
  <img 
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchPriority}
    decoding="async"
    class={className}
    style="width: 100%; height: auto; display: block; object-fit: cover;"
  />
) : (
  <!-- Для локальных изображений используем встроенный Image компонент -->
  <Image
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchPriority={fetchPriority}
    decoding="async"
    class={className}
    format={format}
    style="width: 100%; height: auto; display: block; object-fit: cover;"
  />
)}
